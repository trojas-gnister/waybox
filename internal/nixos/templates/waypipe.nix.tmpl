{{define "waypipe"}}
{{- if not .Config.Headless}}

  # Waybox app launcher daemon (vsock)
  # Listens on vsock port {{.LauncherPort}} for app commands from the host.
  # When a command is received, spawns waypipe server connecting back to
  # the host's waypipe client on port {{.WaypipePort}}.
  environment.etc."waybox-launcher.sh" = {
    text = ''
      #!/bin/sh
      # Set up runtime directory for Wayland
      export XDG_RUNTIME_DIR="/run/user/$(id -u)"
      mkdir -p "$XDG_RUNTIME_DIR"

      read -r APP
      exec ${pkgs.waypipe}/bin/waypipe --vsock --socket 2:{{.WaypipePort}} server -- $APP
    '';
    mode = "0755";
  };

  systemd.services."waybox-launcher" = {
    description = "Waybox app launcher over vsock";
    wantedBy = [ "multi-user.target" ];
    after = [ "network.target" ];
    serviceConfig = {
      ExecStart = "${pkgs.socat}/bin/socat VSOCK-LISTEN:{{.LauncherPort}},reuseaddr,fork EXEC:/etc/waybox-launcher.sh";
      Restart = "always";
      RestartSec = 2;
      User = "user";
    };
  };

  # Ensure XDG_RUNTIME_DIR exists for the user
  systemd.tmpfiles.rules = [
    "d /run/user/1000 0700 user user -"
  ];
{{- if .AudioEnabled}}

  # Audio bridge to host via vsock
  systemd.services."audio-bridge" = {
    description = "Forward audio to host via vsock";
    wantedBy = [ "multi-user.target" ];
    serviceConfig = {
      ExecStart = "${pkgs.socat}/bin/socat UNIX-LISTEN:/tmp/pulse-bridge,fork VSOCK-CONNECT:2:{{.AudioPort}}";
      Restart = "always";
      RestartSec = 2;
      User = "user";
    };
  };

  environment.variables.PULSE_SERVER = "unix:/tmp/pulse-bridge";
{{- end}}
{{- end}}
{{- end}}
